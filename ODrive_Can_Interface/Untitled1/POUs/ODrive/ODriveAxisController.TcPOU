	nIdx : UINT;
END_VAR

VAR_INST
	_eStep : E_OdriveAxisControllerReadStep;
	_rTrig : R_TRIG;
	_tmrTimeOut : TON;
	_uOdriveError : U_OdriveErrorBytes;
	_sErrorMsg : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _eStep OF
	OdriveAxisCtrlRead_Idle:	// Idle
		_rTrig(CLK:= bExecute);
		IF _rTrig.Q THEN
			_rTrig(CLK:= FALSE);
			bBusy := TRUE;			
			_eStep := OdriveAxisCtrlRead_WaitTxReady;
		END_IF

	OdriveAxisCtrlRead_WaitTxReady:	// Check Tx is ready
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nTxReady_TimeOut);

		IF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			_tmrTimeOut(IN:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlRead_AddCmd;

		ELSIF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx ready Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
		END_IF
	
	OdriveAxisCtrlRead_AddCmd: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.GetError), 5) OR SHL(nRTR, 4);
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> _sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlRead_WaitResponse;

		ELSIF bError THEN
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
		END_IF
		
	OdriveAxisCtrlRead_WaitResponse: // Receive command
		_fbODriveCanSimpleTransporter.ReceiveData(NodeId, E_OdriveCmd.GetError, bExist=> bDataExist, stResultCanMsg=> stCanMsg);
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		
		IF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Receive data Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
			
		ELSIF NOT bDataExist THEN	// Not receive data yet
			bBusy := TRUE;
			
		ELSE	// Receive data
			bDone := TRUE;
			FOR nIdx := 0 TO 7 DO
				_uOdriveError.aBytes[nIdx] := stCanMsg.Data[nIdx];
			END_FOR
			stOdriveError := _uOdriveError.stOdriveError;
			_eStep := OdriveAxisCtrlRead_Finish;
		END_IF
	
	OdriveAxisCtrlRead_Finish:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			stOdriveError := _uOdriveError.stOdriveError;
			
		ELSE
			bDone := FALSE;
			_eStep := OdriveAxisCtrlRead_Idle;
		END_IF

	OdriveAxisCtrlRead_Error:	// Error
		IF bExecute THEN
			bError := TRUE;
			sErrorMsg := _sErrorMsg;

		ELSE
			_sErrorMsg := '';
			_eStep := OdriveAxisCtrlRead_Idle;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetHeartBeat" Id="{cb9c0ea2-4e21-4d23-b1eb-ad5840aff9a5}">
      <Declaration><![CDATA[METHOD GetHeartBeat
VAR_INPUT
	bExecute : BOOL;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
	stOdriveHeartBeat : ST_OdriveHeartbeat;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 1;
	
	bAddCmdDone : BOOL;
	bDataExist : BOOL;
	
	nIdx : UINT;
END_VAR

VAR_INST
	_eStep : E_OdriveAxisControllerReadStep;
	_rTrig : R_TRIG;
	_tmrTimeOut : TON;
	_uOdriveHeartBeat : U_OdriveHeartbeatBytes;
	_sErrorMsg : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _eStep OF
	OdriveAxisCtrlRead_Idle:	// Idle
		_rTrig(CLK:= bExecute);
		
		IF _rTrig.Q THEN
			_rTrig(CLK:= FALSE);
			bBusy := TRUE;			
			_eStep := OdriveAxisCtrlRead_WaitTxReady;
		END_IF

	OdriveAxisCtrlRead_WaitTxReady:	// Check Tx is ready
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nTxReady_TimeOut);

		IF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			_tmrTimeOut(IN:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlRead_AddCmd;

		ELSIF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx ready Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
		END_IF
	
	OdriveAxisCtrlRead_AddCmd: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.Heartbeat), 5) OR SHL(nRTR, 4);
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> _sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlRead_WaitResponse;

		ELSIF bError THEN
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
		END_IF
		
	OdriveAxisCtrlRead_WaitResponse: // Receive command
		_fbODriveCanSimpleTransporter.ReceiveData(NodeId, E_OdriveCmd.Heartbeat, bExist=> bDataExist, stResultCanMsg=> stCanMsg);
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		
		IF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Receive data Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
			
		ELSIF NOT bDataExist THEN	// Not receive data yet
			bBusy := TRUE;
			
		ELSE	// Receive data
			bDone := TRUE;
			FOR nIdx := 0 TO 6 DO
				_uOdriveHeartBeat.aBytes[nIdx] := stCanMsg.Data[nIdx];
			END_FOR
			stOdriveHeartBeat := _uOdriveHeartBeat.stHeartbeat;
			_eStep := OdriveAxisCtrlRead_Finish;
		END_IF
	
	OdriveAxisCtrlRead_Finish:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			stOdriveHeartBeat := _uOdriveHeartBeat.stHeartbeat;
			
		ELSE
			bDone := FALSE;
			_eStep := OdriveAxisCtrlRead_Idle;
		END_IF

	OdriveAxisCtrlRead_Error:	// Error
		IF bExecute THEN
			bError := TRUE;
			sErrorMsg := _sErrorMsg;

		ELSE
			_sErrorMsg := '';
			_eStep := OdriveAxisCtrlRead_Idle;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetAbsolutePosition" Id="{9f8e5ac5-4f6b-47bc-8243-567f76d299a4}">
      <Declaration><![CDATA[METHOD SetAbsolutePosition
VAR_INPUT
	bExecute : BOOL;
	rPosition : REAL;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 0;
	nNoOfData : UINT := 4;
	nIdx : UINT;
	
	bAddCmdDone : BOOL;
END_VAR

VAR_INST
	_eStep : E_OdriveAxisControllerWriteStep;
	_rTrig : R_TRIG;
	_tmrTimeOut : TON;
	_uSetAbsolutePosition : U_OdriveSetAbsolutePositionBytes;
	_sErrorMsg : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _eStep OF
	OdriveAxisCtrlWrite_Idle:	// Idle
		_rTrig(CLK:= bExecute);
		
		IF _rTrig.Q THEN
			_rTrig(CLK:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_WaitTxReady;
		END_IF

	OdriveAxisCtrlWrite_WaitTxReady:	// Check Tx is ready
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nTxReady_TimeOut);

		IF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			_tmrTimeOut(IN:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_AddCmd;

		ELSIF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx ready Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
	
	OdriveAxisCtrlWrite_AddCmd: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.Set_AbsPos), 5) OR SHL(nRTR, 4) OR nNoOfData;
		_uSetAbsolutePosition.stSetAbsolutePosition.rPosition := rPosition;
		FOR nIdx := 0 TO 3 DO
			stCanMsg.Data[nIdx] := _uSetAbsolutePosition.aBytes[nIdx];
		END_FOR
		FOR nIdx := 4 TO 7 DO
			stCanMsg.Data[nIdx] := 0;
		END_FOR
		
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> _sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_WaitTxDone;

		ELSIF bError THEN
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
		
	OdriveAxisCtrlWrite_WaitTxDone: // Wait command sent
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		IF _tmrTimeOut.Q THEN
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx done Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		
		ELSIF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			bDone := TRUE;
			_eStep := OdriveAxisCtrlWrite_Finish;
		
		ELSE
			bBusy := TRUE;
		END_IF
	
	OdriveAxisCtrlWrite_Finish:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			
		ELSE
			bDone := FALSE;
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF

	OdriveAxisCtrlWrite_Error:	// Error
		IF bExecute THEN
			bError := TRUE;
			sErrorMsg := _sErrorMsg;

		ELSE
			_sErrorMsg := '';
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetAxisState" Id="{5798b7a5-f8dd-4373-8c17-e10977a10555}">
      <Declaration><![CDATA[METHOD SetAxisState
VAR_INPUT
	bExecute : BOOL;
	eRequestedState : E_OdriveAxisState;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 0;
	nNoOfData : UINT := 1;
	
	bAddCmdDone : BOOL;
	nIdx : UINT;
END_VAR

VAR_INST
	_eStep : E_OdriveAxisControllerWriteStep;
	_rTrig : R_TRIG;
	_tmrTimeOut : TON;
	_uSetAxisState : U_OdriveSetAxisStateBytes;
	_sErrorMsg : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _eStep OF
	OdriveAxisCtrlWrite_Idle:	// Idle
		_rTrig(CLK:= bExecute);
		IF _rTrig.Q THEN
			_rTrig(CLK:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_WaitTxReady;
		END_IF

	OdriveAxisCtrlWrite_WaitTxReady:	// Check Tx is ready
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nTxReady_TimeOut);

		IF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			_tmrTimeOut(IN:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_AddCmd;

		ELSIF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx ready Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
	
	OdriveAxisCtrlWrite_AddCmd: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.SetAxisState), 5) OR SHL(nRTR, 4) OR nNoOfData;
		_uSetAxisState.stSetAxisState.eRequestedState := eRequestedState;
		_uSetAxisState.aBytes[1] := 0;
		_uSetAxisState.aBytes[2] := 0;
		_uSetAxisState.aBytes[3] := 0;
		
		FOR nIdx := 0 TO 3 DO
			stCanMsg.Data[nIdx] := _uSetAxisState.aBytes[nIdx];
		END_FOR
		FOR nIdx := 4 TO 7 DO
			stCanMsg.Data[nIdx] := 0;
		END_FOR
		
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> _sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_WaitTxDone;

		ELSIF bError THEN
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
		
	OdriveAxisCtrlWrite_WaitTxDone: // Wait command sent
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		IF _tmrTimeOut.Q THEN
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx done Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		
		ELSIF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			bDone := TRUE;
			_eStep := OdriveAxisCtrlWrite_Finish;
		
		ELSE
			bBusy := TRUE;
		END_IF
	
	OdriveAxisCtrlWrite_Finish:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			
		ELSE
			bDone := FALSE;
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF

	OdriveAxisCtrlWrite_Error:	// Error
		IF bExecute THEN
			bError := TRUE;
			sErrorMsg := _sErrorMsg;

		ELSE
			_sErrorMsg := '';
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
