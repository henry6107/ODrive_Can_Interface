		END_IF

	OdriveAxisCtrlWrite_WaitTxReady:	// Check Tx is ready
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nTxReady_TimeOut);

		IF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			_tmrTimeOut(IN:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_AddCmd;

		ELSIF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx ready Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
	
	OdriveAxisCtrlWrite_AddCmd: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.Estop), 5) OR SHL(nRTR, 4) OR nNoOfData;
		FOR nIdx := 0 TO 7 DO
			stCanMsg.Data[nIdx] := 0;
		END_FOR
		
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> _sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_WaitTxDone;

		ELSIF bError THEN
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
		
	OdriveAxisCtrlWrite_WaitTxDone: // Wait command sent
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		IF _tmrTimeOut.Q THEN
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx done Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		
		ELSIF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			bDone := TRUE;
			_eStep := OdriveAxisCtrlWrite_Finish;
		
		ELSE
			bBusy := TRUE;
		END_IF
	
	OdriveAxisCtrlWrite_Finish:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			
		ELSE
			bDone := FALSE;
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF

	OdriveAxisCtrlWrite_Error:	// Error
		IF bExecute THEN
			bError := TRUE;
			sErrorMsg := _sErrorMsg;

		ELSE
			_sErrorMsg := '';
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetEncoderEstimates" Id="{14a2520e-b7da-434d-8e95-8a742dcda8c6}">
      <Declaration><![CDATA[METHOD GetEncoderEstimates
VAR_INPUT
	bExecute : BOOL;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
	stOdriveEncoderEstimates : ST_OdriveEncoderEstimates;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 1;
	
	bAddCmdDone : BOOL;
	bDataExist : BOOL;
	
	nIdx : UINT;
END_VAR

VAR_INST
	_eStep : E_OdriveAxisControllerReadStep;
	_rTrig : R_TRIG;
	_tmrTimeOut : TON;
	_uEncoderEstimates : U_OdriveEncoderEstimatesBytes;
	_sErrorMsg : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _eStep OF
	OdriveAxisCtrlRead_Idle:	// Idle
		_rTrig(CLK:= bExecute);
		IF _rTrig.Q THEN
			_rTrig(CLK:= FALSE);
			bBusy := TRUE;			
			_eStep := OdriveAxisCtrlRead_WaitTxReady;
		END_IF
		
	OdriveAxisCtrlRead_WaitTxReady:	// Check Tx is ready
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nTxReady_TimeOut);
			
		IF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			_tmrTimeOut(IN:= FALSE);
			bBusy := TRUE;			
			_eStep := OdriveAxisCtrlRead_AddCmd;
			
		ELSIF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx ready Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
		END_IF
	
	OdriveAxisCtrlRead_AddCmd: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.GetEncoderEstimates), 5) OR SHL(nRTR, 4);
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> _sErrorMsg);
		
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlRead_WaitResponse;
			
		ELSIF bError THEN
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlRead_Error;
		END_IF
		
	OdriveAxisCtrlRead_WaitResponse: // Receive data
		_fbODriveCanSimpleTransporter.ReceiveData(NodeId, E_OdriveCmd.GetEncoderEstimates, bExist=> bDataExist, stResultCanMsg=> stCanMsg);
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		
		IF _tmrTimeOut.Q THEN	// Time out
			bError := TRUE;
			_sErrorMsg := 'Receive data Time out !';
			sErrorMsg := _sErrorMsg;
			_tmrTimeOut(IN:= FALSE);
			_eStep := OdriveAxisCtrlRead_Error;
			
		ELSIF NOT bDataExist THEN	// Not receive data yet
			bBusy := TRUE;
			
		ELSE	// Receive data
			bDone := TRUE;
			FOR nIdx := 0 TO 7 DO
				_uEncoderEstimates.aBytes[nIdx] := stCanMsg.Data[nIdx];
			END_FOR
			stOdriveEncoderEstimates := _uEncoderEstimates.stEncoderEstimates;
			_eStep := OdriveAxisCtrlRead_Finish;
		END_IF
	
	OdriveAxisCtrlRead_Finish:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			stOdriveEncoderEstimates := _uEncoderEstimates.stEncoderEstimates;
			
		ELSE
			bDone := FALSE;
			_eStep := OdriveAxisCtrlRead_Idle;
		END_IF
	
	OdriveAxisCtrlRead_Error:	// Error
		IF bExecute THEN
			bError := TRUE;
			sErrorMsg := _sErrorMsg;
			
		ELSE
			_sErrorMsg := '';
			_eStep := OdriveAxisCtrlRead_Idle;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetError" Id="{7ced9641-2f1e-4dcb-89a3-a01589153701}">
      <Declaration><![CDATA[METHOD GetError
VAR_INPUT
	bExecute : BOOL;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
	stOdriveError : ST_OdriveError;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 1;
	
	bAddCmdDone : BOOL;
