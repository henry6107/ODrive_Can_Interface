<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="ODriveAxisController" Id="{888f14a2-28b4-442c-8d2b-90ee242187e2}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK ODriveAxisController
VAR_INPUT
	NodeId : UINT;
	bEnableAutoHeartBeat : BOOL;
END_VAR

VAR_OUTPUT
	stAutoHeartBeat : ST_OdriveHeartbeat;
	bAutoHeartBeatValid : BOOL;
	bAutoHeartBeatUpdated : BOOL;
	bAutoHeartBeatTimedOut : BOOL;
END_VAR

VAR
	_fbODriveCanSimpleTransporter : ODriveCanSimpleTransporter;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[_fbODriveCanSimpleTransporter();
UpdateAutoHeartBeat();
]]></ST>
    </Implementation>
    <Method Name="ClearErrors" Id="{9f6d8e5d-e30f-48f7-bcb6-5c8ff9cd4fa8}">
      <Declaration><![CDATA[METHOD ClearErrors
VAR_INPUT
	bExecute : BOOL;
	byIdentify : BYTE;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 0;
	nNoOfData : UINT := 1;
	nIdx : UINT;
	
	bAddCmdDone : BOOL;
END_VAR

VAR_INST
	_eStep : E_OdriveAxisControllerWriteStep;
	_rTrig : R_TRIG;
	_tmrTimeOut : TON;
	_sErrorMsg : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _eStep OF
	OdriveAxisCtrlWrite_Idle:	// Idle
		_rTrig(CLK:= bExecute);
		
		IF _rTrig.Q THEN
			_rTrig(CLK:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_WaitTxReady;
		END_IF

	OdriveAxisCtrlWrite_WaitTxReady:	// Check Tx is ready
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nTxReady_TimeOut);

		IF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			_tmrTimeOut(IN:= FALSE);
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_AddCmd;

		ELSIF _tmrTimeOut.Q THEN	// Time out
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx ready Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
	
	OdriveAxisCtrlWrite_AddCmd: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.ClearErrors), 5) OR SHL(nRTR, 4) OR nNoOfData;
		stCanMsg.Data[0] := byIdentify;
		FOR nIdx := 1 TO 7 DO
			stCanMsg.Data[nIdx] := 0;
		END_FOR
		
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> _sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_eStep := OdriveAxisCtrlWrite_WaitTxDone;

		ELSIF bError THEN
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		END_IF
		
	OdriveAxisCtrlWrite_WaitTxDone: // Wait command sent
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		
		IF _tmrTimeOut.Q THEN
			_tmrTimeOut(IN:= FALSE);
			bError := TRUE;
			_sErrorMsg := 'Tx done Time out !';
			sErrorMsg := _sErrorMsg;
			_eStep := OdriveAxisCtrlWrite_Error;
		
		ELSIF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			bDone := TRUE;
			_eStep := OdriveAxisCtrlWrite_Finish;
		
		ELSE
			bBusy := TRUE;
		END_IF
	
	OdriveAxisCtrlWrite_Finish:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			
		ELSE
			bDone := FALSE;
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF

	OdriveAxisCtrlWrite_Error:	// Error
		IF bExecute THEN
			bError := TRUE;
			sErrorMsg := _sErrorMsg;

		ELSE
			_sErrorMsg := '';
			_eStep := OdriveAxisCtrlWrite_Idle;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="Estop" Id="{f764a4b6-a93b-466a-9df9-8df30e9d4691}">
      <Declaration><![CDATA[METHOD Estop
VAR_INPUT
	bExecute : BOOL;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 0;
	nNoOfData : UINT := 0;
	nIdx : UINT;
	
	bAddCmdDone : BOOL;
END_VAR

VAR_INST
	_eStep : E_OdriveAxisControllerWriteStep;
	_rTrig : R_TRIG;
	_tmrTimeOut : TON;
	_sErrorMsg : STRING;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE _eStep OF
