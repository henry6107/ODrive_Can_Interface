		tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		IF tmrTimeOut.Q THEN
			bError := TRUE;
			sErrorMsg := 'Time out !';
		
		ELSIF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			bDone := TRUE;
			nStep := 3;
		
		ELSE
			bBusy := TRUE;
		END_IF
	
	3:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			
		ELSE
			bDone := FALSE;
			rTrig(CLK:= FALSE);
			tmrTimeOut(IN:= FALSE);
			nStep := 0;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
