		ELSE
			bDone := FALSE;
			rTrig(CLK:= FALSE);
			tmrTimeOut(IN:= FALSE);
			nStep := 0;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="GetHeartBeat" Id="{cb9c0ea2-4e21-4d23-b1eb-ad5840aff9a5}">
      <Declaration><![CDATA[METHOD GetHeartBeat
VAR_INPUT
	bExecute : BOOL;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
	stOdriveHeartBeat : ST_OdriveHeartbeat;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 1;
	
	bAddCmdDone : BOOL;
	bDataExist : BOOL;
	
	nIdx : UINT;
END_VAR

VAR_INST
	nStep : UINT;
	rTrig : R_TRIG;
	tmrTimeOut : TON;
	uOdriveHeartBeat : U_OdriveHeartbeatBytes;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE nStep OF
	0:	// Idle
		rTrig(CLK:= bExecute);
		IF rTrig.Q THEN
			bBusy := TRUE;			
			nStep := 1;
		END_IF
	
	1: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.Heartbeat), 5) OR SHL(nRTR, 4);
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			nStep := 2;
		END_IF
		
	2: // Receive command
		_fbODriveCanSimpleTransporter.ReceiveData(NodeId, E_OdriveCmd.Heartbeat, bExist=> bDataExist, stResultCanMsg=> stCanMsg);
		tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		
		IF tmrTimeOut.Q THEN	// Time out
			bError := TRUE;
			sErrorMsg := 'Time out !';
			
		ELSIF NOT bDataExist THEN	// Not receive data yet
			bBusy := TRUE;
			
		ELSE	// Receive data
			bDone := TRUE;
			FOR nIdx := 0 TO 6 DO
				uOdriveHeartBeat.aBytes[nIdx] := stCanMsg.Data[nIdx];
			END_FOR
			stOdriveHeartBeat := uOdriveHeartBeat.stHeartbeat;
			nStep := 3;
		END_IF
	
	3:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			stOdriveHeartBeat := uOdriveHeartBeat.stHeartbeat;
			
		ELSE
			bDone := FALSE;
			rTrig(CLK:= FALSE);
			tmrTimeOut(IN:= FALSE);
			nStep := 0;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetAxisState" Id="{5798b7a5-f8dd-4373-8c17-e10977a10555}">
      <Declaration><![CDATA[METHOD SetAxisState
VAR_INPUT
	bExecute : BOOL;
	eRequestedState : E_OdriveAxisState;
END_VAR

VAR_OUTPUT
	bBusy : BOOL;
	bError : BOOL;
	sErrorMsg : STRING;
	bDone : BOOL;
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	nRTR : UINT := 0;
	nNoOfData : UINT := 1;
	
	bAddCmdDone : BOOL;
	nIdx : UINT;
END_VAR

VAR_INST
	nStep : UINT;
	rTrig : R_TRIG;
	tmrTimeOut : TON;
	uSetAxisState : U_OdriveSetAxisStateBytes;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE nStep OF
	0:	// Idle
		rTrig(CLK:= bExecute);
		IF rTrig.Q THEN
			bBusy := TRUE;
			nStep := 1;
		END_IF
	
	1: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.SetAxisState), 5) OR SHL(nRTR, 4) OR nNoOfData;
		uSetAxisState.stSetAxisState.eRequestedState := eRequestedState;
		uSetAxisState.aBytes[1] := 0;
		uSetAxisState.aBytes[2] := 0;
		uSetAxisState.aBytes[3] := 0;
		
		FOR nIdx := 0 TO 3 DO
			stCanMsg.Data[nIdx] := uSetAxisState.aBytes[nIdx];
		END_FOR
		FOR nIdx := 4 TO 7 DO
			stCanMsg.Data[nIdx] := 0;
		END_FOR
		
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			nStep := 2;
		END_IF
		
	2: // Wait command sent
		tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		IF tmrTimeOut.Q THEN
			bError := TRUE;
			sErrorMsg := 'Time out !';
		
		ELSIF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			bDone := TRUE;
			nStep := 3;
		
		ELSE
			bBusy := TRUE;
		END_IF
	
	3:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			
		ELSE
			bDone := FALSE;
			rTrig(CLK:= FALSE);
			tmrTimeOut(IN:= FALSE);
			nStep := 0;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
