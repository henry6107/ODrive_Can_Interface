		END_IF
	
	1: // Add command
		stCanMsg.CobId := SHL(SHL(NodeId, 5) OR TO_UINT(E_OdriveCmd.SetInputVel), 5) OR SHL(nRTR, 4) OR nNoOfData;
		_uSetInputVel.stSetInputVel.rInputVel := rInputVel;
		_uSetInputVel.stSetInputVel.rInputTorqueFF := rInputTorqueFF;
		
		FOR nIdx := 0 TO 7 DO
			stCanMsg.Data[nIdx] := _uSetInputVel.aBytes[nIdx];
		END_FOR
		
		_fbODriveCanSimpleTransporter.AddCmd(stCanMsg, bDone=> bAddCmdDone, bError=> bError, sErrorMsg=> sErrorMsg);
		IF bAddCmdDone THEN
			bBusy := TRUE;
			_nStep := 2;
		END_IF
		
	2: // Wait command sent
		_tmrTimeOut(IN:= TRUE, PT:= GVL_ODrive.nReceiveData_TimeOut);
		IF _tmrTimeOut.Q THEN
			bError := TRUE;
			sErrorMsg := 'Time out !';
		
		ELSIF _fbODriveCanSimpleTransporter.IsTxDone() THEN
			bDone := TRUE;
			_nStep := 3;
		
		ELSE
			bBusy := TRUE;
		END_IF
	
	3:	// Finish
		IF bExecute THEN
			bDone := TRUE;
			
		ELSE
			bDone := FALSE;
			_rTrig(CLK:= FALSE);
			_tmrTimeOut(IN:= FALSE);
			_nStep := 0;
		END_IF
	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="UpdateAutoHeartBeat" Id="{6c7f1735-84f4-4e40-8c58-60217bc84b28}">
      <Declaration><![CDATA[METHOD PRIVATE UpdateAutoHeartBeat
VAR_INPUT
END_VAR

VAR_OUTPUT
END_VAR

VAR
	stCanMsg : ST_CanMessage;
	bDataExist : BOOL;
	nIdx : UINT;
	nRxCounter : UINT;
END_VAR

VAR_INST
	_tmrAutoHeartBeatTimeOut : TON;
	_uAutoHeartBeat : U_OdriveHeartbeatBytes;
	_nLastAutoHeartBeatRxCounter : UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bAutoHeartBeatUpdated := FALSE;

IF NOT bEnableAutoHeartBeat THEN
	bAutoHeartBeatValid := FALSE;
	bAutoHeartBeatTimedOut := FALSE;
	_tmrAutoHeartBeatTimeOut(IN:= FALSE);
	RETURN;
END_IF

nRxCounter := _fbODriveCanSimpleTransporter.GetRxCounter();
IF nRxCounter <> _nLastAutoHeartBeatRxCounter THEN
	_nLastAutoHeartBeatRxCounter := nRxCounter;
	_fbODriveCanSimpleTransporter.ReceiveData(NodeId, E_OdriveCmd.Heartbeat, bExist=> bDataExist, stResultCanMsg=> stCanMsg);
	
	IF bDataExist THEN
		FOR nIdx := 0 TO 6 DO
			_uAutoHeartBeat.aBytes[nIdx] := stCanMsg.Data[nIdx];
		END_FOR
		
		stAutoHeartBeat := _uAutoHeartBeat.stHeartbeat;
		bAutoHeartBeatValid := TRUE;
		bAutoHeartBeatUpdated := TRUE;
		bAutoHeartBeatTimedOut := FALSE;
		_tmrAutoHeartBeatTimeOut(IN:= FALSE);
	END_IF
END_IF

_tmrAutoHeartBeatTimeOut(IN:= TRUE, PT:= GVL_ODrive.nAutoHeartBeat_TimeOut);
IF _tmrAutoHeartBeatTimeOut.Q THEN
	bAutoHeartBeatValid := FALSE;
	bAutoHeartBeatTimedOut := TRUE;
ELSE
	bAutoHeartBeatTimedOut := FALSE;
END_IF]]></ST>
      </Implementation>
    </Method>
